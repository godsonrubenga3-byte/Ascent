{
  "name": "react-example",
  "private": true,
  "version": "0.1.0",
  "description": "Solo leveling style partner scheduler and discipline system for couples.",
  "author": "Duo Leveling Team",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "tsx app-server.ts",
    "build": "vite build && esbuild app-server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "desktop:build": "electron-builder --win",
    "mobile:android:add": "cap add android",
    "mobile:android:sync": "cap sync android",
    "mobile:android:open": "cap open android"
  },
  "build": {
    "appId": "com.duoleveling.covenant",
    "productName": "DuoLeveling",
    "directories": {
      "output": "build-desktop"
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ]
    },
    "msi": {
      "oneClick": true,
      "perMachine": true
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ]
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
